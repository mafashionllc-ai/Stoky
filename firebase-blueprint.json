{
  "entities": {
    "TreatmentLine": {
      "title": "Treatment Line",
      "description": "Beauty treatment line (e.g., Hidratherapy)",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "color": { "type": "string" },
        "emoji": { "type": "string" },
        "descripcion": { "type": "string" },
        "activa": { "type": "boolean" },
        "orden": { "type": "number" },
        "creadoEn": { "type": "string", "format": "date-time" }
      },
      "required": ["nombre", "color", "emoji", "activa"]
    },
    "Product": {
      "title": "Product",
      "description": "S Professional salon product",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "lineaId": { "type": "string" },
        "emoji": { "type": "string" },
        "descripcion": { "type": "string" },
        "tipo": { "enum": ["after_care", "salon", "cabina", "ambos"] },
        "stockActual": { "type": "number" },
        "stockMinimo": { "type": "number" },
        "precio": { "type": "number" },
        "costo": { "type": "number" },
        "unidad": { "type": "string" },
        "codigo": { "type": "string" },
        "activo": { "type": "boolean" },
        "creadoEn": { "type": "string", "format": "date-time" },
        "actualizadoEn": { "type": "string", "format": "date-time" }
      },
      "required": ["nombre", "lineaId", "stockActual", "stockMinimo"]
    },
    "Movement": {
      "title": "Movement",
      "description": "Stock movement (income or outcome)",
      "type": "object",
      "properties": {
        "productoId": { "type": "string" },
        "lineaId": { "type": "string" },
        "tipo": { "enum": ["ingreso", "egreso"] },
        "cantidad": { "type": "number" },
        "stockAnterior": { "type": "number" },
        "stockNuevo": { "type": "number" },
        "nota": { "type": "string" },
        "usuarioId": { "type": "string" },
        "fechaHora": { "type": "string", "format": "date-time" }
      },
      "required": ["productoId", "lineaId", "tipo", "cantidad", "stockAnterior", "stockNuevo", "usuarioId"]
    },
    "Promotion": {
      "title": "Promotion",
      "description": "Discount promotion",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "productos": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productoId": { "type": "string" },
              "nombre": { "type": "string" },
              "precioUnitario": { "type": "number" }
            }
          }
        },
        "subtotalRegular": { "type": "number" },
        "tipoDescuento": { "enum": ["porcentaje", "monto_fijo"] },
        "valorDescuento": { "type": "number" },
        "totalFinal": { "type": "number" },
        "activa": { "type": "boolean" },
        "creadoEn": { "type": "string", "format": "date-time" },
        "usuarioId": { "type": "string" }
      },
      "required": ["nombre", "subtotalRegular", "tipoDescuento", "valorDescuento", "totalFinal", "activa"]
    },
    "DeliveryNote": {
      "title": "Delivery Note",
      "description": "Document for product delivery with tax and discount calculations",
      "type": "object",
      "properties": {
        "nroNota": { "type": "string" },
        "receptor": { "type": "string" },
        "fecha": { "type": "string", "format": "date-time" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productoId": { "type": "string" },
              "nombre": { "type": "string" },
              "cantidad": { "type": "number" },
              "precioUnitario": { "type": "number" },
              "subtotal": { "type": "number" }
            }
          }
        },
        "subtotal": { "type": "number" },
        "aplicarTax": { "type": "boolean" },
        "taxRate": { "type": "number" },
        "taxAmount": { "type": "number" },
        "tipoDescuento": { "enum": ["porcentaje", "monto_fijo"] },
        "valorDescuento": { "type": "number" },
        "montoDescuento": { "type": "number" },
        "costoEnvio": { "type": "number" },
        "total": { "type": "number" },
        "usuarioId": { "type": "string" },
        "observaciones": { "type": "string" },
        "statusArmado": { "type": "boolean" },
        "statusEntregado": { "type": "boolean" },
        "statusCobrado": { "type": "boolean" },
        "archived": { "type": "boolean" }
      },
      "required": ["nroNota", "receptor", "fecha", "items", "total", "usuarioId"]
    }
  },
  "firestore": {
    "lineas_tratamiento/{lineaId}": {
      "schema": "TreatmentLine",
      "description": "Collections of beauty treatment lines"
    },
    "productos/{productoId}": {
      "schema": "Product",
      "description": "Catalog of S Professional products"
    },
    "movimientos/{movimientoId}": {
      "schema": "Movement",
      "description": "Log of all stock movements"
    },
    "promociones/{promoId}": {
      "schema": "Promotion",
      "description": "Promotional offers and bundles"
    },
    "notas_entrega/{notaId}": {
      "schema": "DeliveryNote",
      "description": "Registry of all delivery notes issued"
    }
  }
}
